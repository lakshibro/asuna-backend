# Asuna Backend Environment Configuration

# Required: Your Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (default: 3848)
PORT=3848

# WhatsApp Bot API URL (for proactive triggers)
# On the same droplet, use localhost. Adjust if running elsewhere.
BOT_URL=http://127.0.0.1:3847
